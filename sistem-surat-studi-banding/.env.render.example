# Example environment for Render (web) + Supabase (Postgres)
# Copy to `.env.production` or set these as environment variables in Render.

APP_NAME=Laravel
APP_ENV=production
# Generate and paste APP_KEY (php artisan key:generate --show)
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-render-service.onrender.com

# Locale
APP_LOCALE=en

# Database (Supabase)
DB_CONNECTION=pgsql
# Either set DB_URL or the individual values below. Supabase provides a connection string.
DB_URL=
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_SSLMODE=require

SESSION_DRIVER=database
SESSION_LIFETIME=120

# Cache / Queue (optional: configure Redis or keep database)
CACHE_STORE=database
QUEUE_CONNECTION=database

# Filesystem: consider S3 or Supabase Storage for production
FILESYSTEM_DISK=local

# Mail - configure real SMTP in production
MAIL_MAILER=log

# Other production-safe defaults
LOG_CHANNEL=stack
LOG_LEVEL=info
